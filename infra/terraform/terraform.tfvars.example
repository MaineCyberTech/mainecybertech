aws_region                   = "us-east-1"
environment                  = "dev"
vercel_team_id               = "YOUR_VERCEL_TEAM_ID"
supabase_org_slug            = "YOUR_SUPABASE_ORG"
supabase_region               = "us-east-1"
db_password                  = "YOUR_SUPABASE_DB_PASSWORD"
supabase_anon_key            = "eyJxxxxx"
supabase_service_role_key     = "eyJxxxxx"
jwt_secret                   = "your-jwt-secret-min-32-chars"
cors_origin                   = "https://app.mainecybertech.com"
github_repo                  = "your-username/maine-cybertech-portal"
github_repository             = "your-username/maine-cybertech-portal"
api_domain                   = "api.yourdomain.com"
ecs_cluster_name             = "mainecybertech-cluster"
api_service_name              = "mainecybertech-api-service"
worker_service_name           = "mainecybertech-worker-service"
alb_name                     = "mct-api-alb"
acm_certificate_arn          = "arn:aws:acm:us-east-1:123456789:certificate/xxxxx"
cloudflare_zone_id_prod      = "YOUR_CLOUDFLARE_ZONE_ID_PROD"
cloudflare_zone_id_test      = "YOUR_CLOUDFLARE_ZONE_ID_TEST"
cloudflare_prod_app_target   = "cname.vercel-dns.com"
cloudflare_prod_api_target    = "your-alb-dns.elb.amazonaws.com"
cloudflare_test_app_target   = "cname.vercel-dns.com"
cloudflare_test_api_target   = "your-alb-dns.elb.amazonaws.com"
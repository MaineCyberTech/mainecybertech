# Dev / testing starter file
# Intended for: app.mainecybertech.us and api.mainecybertech.us

aws_region                    = "us-east-1"
vercel_team_id                = "team_xxxxxxxxxxxx"
supabase_org_slug             = "your-org-slug"
github_repo                   = "yourusername/mainecybertech-monorepo"
github_repository             = "yourusername/mainecybertech-monorepo"

# Testing DNS targets
cloudflare_zone_id_test       = "replace-with-cloudflare-zone-id-for-mainecybertech.us"
cloudflare_test_app_name      = "app"
cloudflare_test_api_name      = "api"
cloudflare_test_app_target    = "replace-with-vercel-inspect-target-for-app.mainecybertech.us"
cloudflare_test_api_target    = "replace-with-testing-alb-dns-name"
cloudflare_proxy_app_records  = true
cloudflare_proxy_api_records  = false

# Vercel web app vars
vercel_ga_id                  = "G-1JYZ96P0D9"
vercel_tawkto_id              = "66898d27e1e4f70f24ee3260/1i24kuosn"
# vercel_sentry_dsn           = "https://key@o123.ingest.sentry.io/project"

# Runtime sizing
api_service_desired_count      = 1
worker_service_desired_count   = 1
api_container_port             = 3001
api_health_check_path          = "/health"
acm_certificate_arn            = "arn:aws:acm:us-east-1:123456789012:certificate/replace-me-testing"

# Autoscaling
api_autoscaling_min_capacity    = 1
api_autoscaling_max_capacity    = 2
worker_autoscaling_min_capacity = 1
worker_autoscaling_max_capacity = 2
api_cpu_target_value            = 60
worker_cpu_target_value         = 60

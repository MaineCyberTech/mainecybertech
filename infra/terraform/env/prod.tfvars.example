# Production starter file
# Intended for: app.mainecybertech.com and api.mainecybertech.com

aws_region                    = "us-east-1"
vercel_team_id                = "team_xxxxxxxxxxxx"
supabase_org_slug             = "your-org-slug"
github_repo                   = "yourusername/mainecybertech-monorepo"
github_repository             = "yourusername/mainecybertech-monorepo"

# Production DNS targets
cloudflare_zone_id_prod       = "replace-with-cloudflare-zone-id-for-mainecybertech.com"
cloudflare_prod_app_name      = "app"
cloudflare_prod_api_name      = "api"
cloudflare_prod_app_target    = "replace-with-vercel-inspect-target-for-app.mainecybertech.com"
cloudflare_prod_api_target    = "replace-with-production-alb-dns-name"
cloudflare_proxy_app_records  = true
cloudflare_proxy_api_records  = true

# Runtime sizing
api_service_desired_count      = 2
worker_service_desired_count   = 1
api_container_port             = 3001
api_health_check_path          = "/health"
acm_certificate_arn            = "arn:aws:acm:us-east-1:123456789012:certificate/replace-me-production"

# Autoscaling
api_autoscaling_min_capacity    = 2
api_autoscaling_max_capacity    = 4
worker_autoscaling_min_capacity = 1
worker_autoscaling_max_capacity = 3
api_cpu_target_value            = 60
worker_cpu_target_value         = 60

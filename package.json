{
  "name": "client-portal",
  "private": true,
  "packageManager": "pnpm@10.34.3",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:coverage": "turbo run test:coverage",
    "e2e": "pnpm --filter=web e2e",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "prepare": "husky",
    "supabase:env:sync": "powershell -ExecutionPolicy Bypass -File ./scripts/sync_supabase_env.auto.v2.ps1 -UseNpx -Framework nextjs -EnvFile .env.local",
    "dev:autoenv": "powershell -ExecutionPolicy Bypass -File ./scripts/start_project_with_supabase_env.ps1 -UseNpx -Framework nextjs -EnvFile .env.local -Command \"npm run dev\"",
    "dev:autoenv:vite": "powershell -ExecutionPolicy Bypass -File ./scripts/start_project_with_supabase_env.ps1 -UseNpx -Framework vite -EnvFile .env -Command \"npm run dev\"",
    "supabase:reset:auto": "powershell -ExecutionPolicy Bypass -File ./scripts/local_dev_reset_and_verify.automated.v2.ps1 -UseNpx"
  },
  "devDependencies": {
    "@playwright/test": "1.61.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "pg": "^8.21.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.4",
    "supabase": "^2.107.0",
    "supabase-cli": "^0.0.21",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@sentry/cli"
    ],
    "overrides": {
      "postcss": ">=8.5.10",
      "js-yaml": ">=4.2.0",
      "@opentelemetry/core": "2.7.0",
      "esbuild": ">=0.28.1",
      "form-data": ">=4.0.6",
      "multer": "2.2.0"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write"
    ],
    "*.{js,mjs,cjs,json,md}": [
      "prettier --write"
    ]
  }
}
